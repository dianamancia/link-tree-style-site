---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{name} · {bio}</title>
    <meta name="description" content={`${name} — ${bio}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <img class="avatar" src={photo} alt={name} width="120" height="120" />
      <h1>{name}</h1>
      <p class="bio">{bio}</p>

      <nav class="links">
        {
          links.map((link) => (
            <a
              class="link"
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="icon" set:html={icons[link.icon]} />
              <span class="label">{link.label}</span>
              <span class="spacer" />
            </a>
          ))
        }
      </nav>

      <footer>© {new Date().getFullYear()} {name}</footer>
    </main>
  </body>
</html>

<style>
  :root {
    --text: #1a1530;
    --muted: #6b6580;
    --card: rgba(255, 255, 255, 0.7);
    --card-hover: rgba(255, 255, 255, 0.95);
    --border: rgba(255, 255, 255, 0.6);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1.25rem;
    background: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 50%, #c2e9fb 100%);
    background-attachment: fixed;
    -webkit-font-smoothing: antialiased;
  }

  main {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 10px 30px rgba(70, 50, 120, 0.25);
  }

  h1 {
    margin-top: 1.25rem;
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .bio {
    margin-top: 0.35rem;
    font-size: 1rem;
    color: var(--muted);
    font-weight: 500;
  }

  .links {
    margin-top: 2rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.95rem 1.25rem;
    border-radius: 16px;
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 14px rgba(70, 50, 120, 0.1);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      background 0.18s ease;
  }

  .link:hover {
    transform: translateY(-3px) scale(1.01);
    background: var(--card-hover);
    box-shadow: 0 12px 28px rgba(70, 50, 120, 0.2);
  }

  .link:active {
    transform: translateY(-1px) scale(1);
  }

  .icon {
    display: inline-flex;
    flex-shrink: 0;
  }

  .icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .label {
    flex: 1;
    text-align: left;
  }

  /* keeps the label visually centered against the leading icon */
  .spacer {
    width: 22px;
    flex-shrink: 0;
  }

  footer {
    margin-top: 2.5rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
