const name = "Diana Mancía";
const bio = "Product Designer";
const photo = "/profile.jpeg"; // your photo lives in /public — swap the file or change this path anytime

const links = [
  {
    label: "LinkedIn",
    url: "https://www.linkedin.com/in/mancia-diana/",
    icon: "linkedin",
  },
  {
    label: "Twitter / X",
    url: "https://x.com/dianapotterish?s=11",
    icon: "x",
  },
  {
    label: "Instagram",
    url: "https://www.instagram.com/dialuna7?igsh=aTVlZG1lcHZ3NHVq&utm_source=qr",
    icon: "instagram",
  },
];
// ─────────────────────────────────────────────────────────────
//  No need to edit below this line for normal changes.
// ─────────────────────────────────────────────────────────────

const svg = (path: string) =>
  `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">${path}</svg>`;

const icons: Record<string, string> = {
