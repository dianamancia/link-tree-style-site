  {
    label: "LinkedIn",
    url: "https://www.linkedin.com/in/mancia-diana/",
    icon: "linkedin",
  },
  {
    label: "Twitter / X",
    url: "https://x.com/dianapotterish?s=11",
    icon: "x",
  },
  {
    label: "Instagram",
    url: "https://www.instagram.com/dialuna7?igsh=aTVlZG1lcHZ3NHVq&utm_source=qr",
    icon: "instagram",
  },
];
// ─────────────────────────────────────────────────────────────
