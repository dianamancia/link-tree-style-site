---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{name} · {bio}</title>
    <meta name="description" content={`${name} — ${bio}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="blobs" aria-hidden="true">
      <div class="blob b1"></div>
      <div class="blob b2"></div>
      <div class="blob b3"></div>
      <div class="blob b4"></div>
      <div class="blob b5"></div>
    </div>
    <div class="card">
      <main>
        <img class="avatar" src={photo} alt={name} width="120" height="120" />
        <h1>{name}</h1>
        <p class="bio">{bio}</p>

        <nav class="links">
          {
            links.map((link) => (
              <a
                class="link"
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="icon" set:html={icons[link.icon]} />
                <span class="label">{link.label}</span>
                <span class="spacer" />
              </a>
            ))
          }
        </nav>

        <footer>© {new Date().getFullYear()} {name}</footer>
      </main>
    </div>
  </body>
</html>

<style>
  :root {
    --text:      #0d3d45;
    --muted:     #3a7d88;
    --link-bg:   rgba(255, 255, 255, 0.22);
    --link-hover:rgba(255, 255, 255, 0.38);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1.25rem;
    -webkit-font-smoothing: antialiased;
    background: #2dcfcf; /* base fallback */
    overflow: hidden;
    position: relative;
  }

  /* ── Organic blob layer ── */
  .blobs {
    position: fixed;
    inset: -20%;          /* oversized so blobs don't clip at edges */
    z-index: 0;
    filter: blur(90px);   /* softens blobs into a smooth mesh */
    overflow: hidden;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.85;
    will-change: transform;
  }

  /* Each blob: different size, color, start position, and animation */
  .b1 {
    width: 70vw; height: 70vw;
    background: radial-gradient(circle, #72e8e0, #3ecfcf 60%, transparent);
    top: -10%; left: -10%;
    animation: drift1 22s ease-in-out infinite;
  }
  .b2 {
    width: 55vw; height: 55vw;
    background: radial-gradient(circle, #b8f5e6, #7de8c0 60%, transparent);
    top: 30%; right: -15%;
    animation: drift2 28s ease-in-out infinite;
  }
  .b3 {
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, #c6faf0, #a8edea 60%, transparent);
    bottom: -15%; left: 15%;
    animation: drift3 20s ease-in-out infinite;
  }
  .b4 {
    width: 45vw; height: 45vw;
    background: radial-gradient(circle, #1ab8c4, #0e8fa0 60%, transparent);
    top: 10%; right: 10%;
    animation: drift4 32s ease-in-out infinite;
  }
  .b5 {
    width: 50vw; height: 50vw;
    background: radial-gradient(circle, #d4fdf4, #72e8e0 60%, transparent);
    bottom: 5%; right: -5%;
    animation: drift5 25s ease-in-out infinite;
  }

  @keyframes drift1 {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(12vw, 18vh) scale(1.1); }
    66%  { transform: translate(-8vw, 30vh) scale(0.95); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes drift2 {
    0%   { transform: translate(0, 0) scale(1); }
    40%  { transform: translate(-20vw, -15vh) scale(1.15); }
    70%  { transform: translate(-10vw, 10vh) scale(0.9); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes drift3 {
    0%   { transform: translate(0, 0) scale(1); }
    30%  { transform: translate(15vw, -20vh) scale(1.05); }
    60%  { transform: translate(5vw, -10vh) scale(1.1); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes drift4 {
    0%   { transform: translate(0, 0) scale(1); }
    50%  { transform: translate(-18vw, 20vh) scale(1.2); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes drift5 {
    0%   { transform: translate(0, 0) scale(1); }
    35%  { transform: translate(-12vw, -18vh) scale(0.9); }
    65%  { transform: translate(8vw, -8vh) scale(1.1); }
    100% { transform: translate(0, 0) scale(1); }
  }

  /* ── Card ── */
  .card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 480px;
    border-radius: 24px;
    padding: 2.5rem 2rem;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  /* Gradient border via mask technique */
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 24px;
    padding: 1.5px;
    background: linear-gradient(
      135deg,
      rgba(114, 232, 224, 0.5),
      rgba(62, 207, 207, 0.5),
      rgba(184, 245, 230, 0.5),
      rgba(125, 232, 192, 0.5)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(255, 255, 255, 0.7);
    box-shadow: 0 8px 24px rgba(14, 143, 160, 0.3);
  }

  h1 {
    margin-top: 1.25rem;
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .bio {
    margin-top: 0.35rem;
    font-size: 1rem;
    color: var(--muted);
    font-weight: 500;
  }

  .links {
    margin-top: 2rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.95rem 1.25rem;
    border-radius: 14px;
    background: var(--link-bg);
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 2px 10px rgba(14, 143, 160, 0.12);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      background 0.18s ease;
  }

  .link:hover {
    transform: translateY(-3px) scale(1.01);
    background: var(--link-hover);
    box-shadow: 0 10px 24px rgba(14, 143, 160, 0.22);
  }

  .link:active { transform: translateY(-1px) scale(1); }

  .icon { display: inline-flex; flex-shrink: 0; }

  .icon :global(svg) { width: 22px; height: 22px; }

  .label { flex: 1; text-align: left; }

  .spacer { width: 22px; flex-shrink: 0; }

  footer {
    margin-top: 2.5rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
